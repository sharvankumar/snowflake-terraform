# Copy this file to terraform.tfvars and fill in your values
# WARNING: Never commit terraform.tfvars to version control

# --- Snowflake Connection ---
snowflake_organization_name = "YOUR_ORG"
snowflake_account_name      = "YOUR_ACCOUNT"
snowflake_user              = "TERRAFORM_SVC"
snowflake_private_key_path  = "~/.ssh/snowflake_tf_snow_key.p8"

# --- Environment ---
environment = "dev"

# --- Snowflake Objects ---
database_name     = "ECOM_ANALYTICS"
schema_name       = "SALES"
warehouse_name    = "ECOM_ANALYTICS_WH"
service_user_name = "ECOM_ANALYTICS_SVC"

# --- Warehouse ---
warehouse_size = "XSMALL"
